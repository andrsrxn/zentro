{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions=development src/index.ts",
    "lint": "biome check",
    "build:types": "tsc",
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.mjs",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "pnpm db:generate && pnpm db:migrate",
    "db:auth:docs": "open-cli http://localhost:8000/v1/auth/reference "
  },
  "exports": {
    "./client": {
      "types": "./dist-types/src/client.d.ts"
    }
  },
  "dependencies": {
    "@hono/node-server": "2.0.4",
    "@hono/zod-validator": "0.8.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@zentro/constants": "workspace:*",
    "@zentro/schemas": "workspace:*",
    "@zentro/utils": "workspace:*",
    "better-auth": "1.6.11",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "vitest": "4.1.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@zentro/ts-config": "workspace:*",
    "@zentro/tsdown-config": "workspace:*",
    "@zentro/vitest-config": "workspace:*",
    "drizzle-kit": "0.31.10",
    "open-cli": "9.0.0",
    "tsdown": "0.22.0",
    "tsx": "4.22.3"
  }
}
