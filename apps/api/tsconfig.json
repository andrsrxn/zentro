{
  "extends": "@zentro/ts-config/hono",
  "compilerOptions": {
    "types": ["node"],
    "outDir": "./dist-types",
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": [
    "src/**/*",
    "tsdown.config.ts",
    "vitest.config.ts",
    "__tests__/**/*.ts",
    "drizzle.config.ts"
  ],
  "exclude": [".turbo", "node_modules", "dist", "dist-types"]
}
