{
  "extends": "@zentro/ts-config/nextjs",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "vitest.config.ts",
    "**/*.mts"
  ],
  "exclude": [".turbo", ".next", "node_modules"],
  "references": [
    {
      "path": "../api"
    }
  ]
}
