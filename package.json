{
  "name": "zentro",
  "description": "Notes App Full Stack Project",
  "version": "1.0.0",
  "author": {
    "name": "Andrés Raxón",
    "email": "andresraxon.art@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint && echo Lint finished",
    "format": "prettier --write . && echo Format finished",
    "typecheck": "turbo run typecheck && echo Typecheck finished",
    "db:generate": "turbo run db:generate && echo DB Generate finished",
    "db:migrate": "turbo run db:migrate && echo DB Migrate finished",
    "db:push": "turbo run db:push && echo DB Push finished",
    "db:studio": "turbo run db:studio",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "build:api": "turbo run build --filter=api",
    "build:web": "turbo run build --filter=web",
    "lint:web": "turbo run lint --filter=web",
    "lint:api": "turbo run lint --filter=api",
    "lint:constants": "turbo run lint --filter=@zentro/constants",
    "lint:tsdown-config": "turbo run lint --filter=@zentro/tsdown-config",
    "lint:vitest-config": "turbo run lint --filter=@zentro/vitest-config",
    "lint:ts-config": "turbo run lint --filter=@zentro/ts-config",
    "lint:utils": "turbo run lint --filter=@zentro/utils",
    "typecheck:web": "turbo run typecheck --filter=web",
    "typecheck:api": "turbo run typecheck --filter=api",
    "typecheck:constants": "turbo run typecheck --filter=@zentro/constants",
    "typecheck:tsdown-config": "turbo run typecheck --filter=@zentro/tsdown-config",
    "typecheck:vitest-config": "turbo run typecheck --filter=@zentro/vitest-config",
    "typecheck:ts-config": "turbo run typecheck --filter=@zentro/ts-config",
    "typecheck:utils": "turbo run typecheck --filter=@zentro/utils",
    "format:web": "turbo run format --filter=web",
    "format:api": "turbo run format --filter=api",
    "format:constants": "turbo run format --filter=@zentro/constants",
    "format:tsdown-config": "turbo run format --filter=@zentro/tsdown-config",
    "format:vitest-config": "turbo run format --filter=@zentro/vitest-config",
    "format:ts-config": "turbo run format --filter=@zentro/ts-config",
    "format:utils": "turbo run format --filter=@zentro/utils",
    "test": "turbo run test",
    "test:web": "turbo run test --filter=web",
    "test:api": "turbo run test --filter=api",
    "test:utils": "turbo run test --filter=@zentro/utils",
    "test:schemas": "turbo run test --filter=@zentro/schemas",
    "clean": "pnpm -r exec rm -rf node_modules .turbo dist && echo Clean finished"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "2.9.6",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24",
    "pnpm": "^10"
  }
}
