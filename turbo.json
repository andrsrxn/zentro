{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",

  "globalDependencies": [
    ".env",
    ".env.local",
    "tsconfig.json"
  ],

   "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^typecheck", "^lint", "^build"],  
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
     "dev": {
      "cache": false,
      "persistent": true
    },
 "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    
    "lint": {
      "outputs": []
    },

    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },

    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
  }
}
